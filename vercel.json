{
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index,follow"
        }
      ]
    }
  ]
}

